{
  "name": "@open333crm/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:gui": "pnpm --filter @open333crm/database run db:gui"
  },
  "dependencies": {
    "@fastify/caching": "^8.0.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "@open333crm/automation": "workspace:*",
    "@open333crm/brain": "workspace:*",
    "@open333crm/channel-plugins": "workspace:*",
    "@open333crm/database": "workspace:*",
    "@open333crm/types": "workspace:*",
    "@prisma/client": "^5.13.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.11.24",
    "prisma": "^5.13.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}