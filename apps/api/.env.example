NODE_ENV=development
PORT=3000

# Docker Compose service names: postgres / redis / minio
DATABASE_URL=postgresql://crm_user:crm_pass@postgres:5432/open333crm?schema=public
REDIS_URL=redis://:changeme@redis:6379
CACHE_DRIVER=redis
CACHE_SEGMENT=open333crm-api-cache
CACHE_REDIS_DB=0
# Optional, seconds for HTTP cache-control max-age
# CACHE_EXPIRES_IN=60

# Required secrets
JWT_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars
CREDENTIAL_ENCRYPTION_KEY=change-me-32-bytes-encryption-key!!

# Required license fields
LICENSE_KEY=lic_local_dev
LICENSE_FETCH_URL=https://license.open333crm.com/v1/licenses/lic_local_dev
LICENSE_SIGNATURE_SECRET=local-dev-signature-secret

# Optional / defaults in env.ts
CORS_ORIGIN=http://localhost:3001
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=open333crm
MINIO_PUBLIC_BASE_URL=http://localhost:9000/open333crm

# Optional integrations
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
