NODE_ENV=development
PORT=3001

# Local development values matching docker-compose published ports.
# The current API bootstrap loads the repo-root `.env` first; keep this file in sync
# if you use it as a template for that root config.
DATABASE_URL=postgresql://crm:crmpassword@localhost:5433/open333crm
REDIS_URL=redis://localhost:6380
CACHE_DRIVER=redis
CACHE_SEGMENT=open333crm-api-cache
CACHE_REDIS_DB=0
# Optional, seconds for HTTP cache-control max-age
# CACHE_EXPIRES_IN=60

# Required secrets
JWT_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars
CREDENTIAL_ENCRYPTION_KEY=change-me-32-bytes-encryption-key!!

# Required license fields
LICENSE_KEY=lic_local_dev
LICENSE_FETCH_URL=https://license.open333crm.com/v1/licenses/lic_local_dev
LICENSE_SIGNATURE_SECRET=local-dev-signature-secret

# Optional / defaults in env.ts
CORS_ORIGIN=http://localhost:3001
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=open333crm
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# Optional integrations
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=bge-m3
