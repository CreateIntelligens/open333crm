{
  "name": "@open333crm/web",
  "version": "0.0.1",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "sync:widget": "pnpm --filter @open333crm/shared build && pnpm --filter @open333crm/widget build && mkdir -p public/webchat && cp ../widget/dist/widget.js public/webchat/widget.js",
    "dev": "pnpm sync:widget && next dev --port 3000",
    "build": "pnpm sync:widget && next build",
    "start": "next start"
  },
  "dependencies": {
    "@open333crm/shared": "workspace:*",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-querybuilder": "^8.15.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3"
  }
}
