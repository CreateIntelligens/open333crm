// ─────────────────────────────────────────────
// Fan Portal
// ─────────────────────────────────────────────

model PortalActivity {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String               @db.Uuid
  type        PortalActivityType
  status      PortalActivityStatus @default(DRAFT)
  title       String
  description String?
  coverImage  String?
  settings    Json                 @default("{}")
  startsAt    DateTime?
  endsAt      DateTime?
  publishedAt DateTime?
  createdById String               @db.Uuid
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  options     PortalOption[]
  fields      PortalField[]
  submissions PortalSubmission[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("portal_activities")
}

model PortalOption {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId String  @db.Uuid
  label      String
  imageUrl   String?
  sortOrder  Int     @default(0)
  isCorrect  Boolean @default(false)

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("portal_options")
}

model PortalField {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId String  @db.Uuid
  fieldKey   String
  label      String
  fieldType  String  @default("text")
  options    Json    @default("[]")
  isRequired Boolean @default(false)
  sortOrder  Int     @default(0)

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("portal_fields")
}

model PortalSubmission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId   String   @db.Uuid
  contactId    String   @db.Uuid
  tenantId     String   @db.Uuid
  answers      Json     @default("{}")
  score        Int?
  isWinner     Boolean  @default(false)
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  contact  Contact        @relation(fields: [contactId], references: [id])
  tenant   Tenant         @relation(fields: [tenantId], references: [id])

  @@index([activityId, contactId])
  @@map("portal_submissions")
}

model PointTransaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  contactId String   @db.Uuid
  amount    Int
  balance   Int
  type      String
  refId     String?  @db.Uuid
  note      String?
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId, contactId])
  @@index([contactId, createdAt(sort: Desc)])
  @@map("point_transactions")
}

