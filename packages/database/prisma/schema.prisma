// ─────────────────────────────────────────────
// Interaction Canvas
// ─────────────────────────────────────────────

model InteractionFlow {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String     @db.Uuid
  name          String
  description   String?
  status        FlowStatus @default(DRAFT)
  triggerType   String
  triggerConfig Json       @default("{}")
  maxStepLimit  Int        @default(100)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  nodes      InteractionNode[]
  executions FlowExecution[]

  @@index([tenantId, status])
  @@map("interaction_flows")
}

model InteractionNode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId      String   @db.Uuid
  nodeType    NodeType
  label       String
  config      Json     @default("{}")
  position    Json     @default("{}")
  nextNodeId  String?  @db.Uuid
  falseNodeId String?  @db.Uuid
  sortOrder   Int      @default(0)

  flow InteractionFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("interaction_nodes")
}

model FlowExecution {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId        String         @db.Uuid
  contactId     String         @db.Uuid
  tenantId      String         @db.Uuid
  status        ExecutionState @default(RUNNING)
  currentNodeId String?        @db.Uuid
  contextVars   Json           @default("{}")
  stepCount     Int            @default(0)
  resumeAt      DateTime?
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  flow   InteractionFlow @relation(fields: [flowId], references: [id])
  tenant Tenant          @relation(fields: [tenantId], references: [id])
  logs   FlowLog[]

  @@index([tenantId, status])
  @@index([resumeAt])
  @@index([contactId])
  @@map("flow_executions")
}

model FlowLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId String   @db.Uuid
  nodeId      String?  @db.Uuid
  action      String
  result      Json     @default("{}")
  createdAt   DateTime @default(now())

  execution FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("flow_logs")
}

// ─────────────────────────────────────────────
// 身分串接（Identity Stitching）
// ─────────────────────────────────────────────

model IdentityMap {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  contactId   String       @db.Uuid
  channelType ChannelType
  uid         String
  source      StitchSource
  confidence  Float        @default(1.0)
  mergedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, channelType, uid])
  @@index([contactId])
  @@map("identity_maps")
}

model MergeSuggestion {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @db.Uuid
  primaryContactId   String           @db.Uuid
  secondaryContactId String           @db.Uuid
  reason             String
  confidence         Float
  status             SuggestionStatus @default(PENDING)
  reviewedById       String?          @db.Uuid
  reviewedAt         DateTime?
  createdAt          DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@map("merge_suggestions")
}