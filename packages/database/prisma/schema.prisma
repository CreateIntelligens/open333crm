  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  tagOnClick   String?   @db.Uuid
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  totalClicks  Int       @default(0)
  uniqueClicks Int       @default(0)
