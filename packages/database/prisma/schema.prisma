generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pgcrypto]
}

// ─────────────────────────────────────────────
// 基礎：Tenant（企業客戶）
// ─────────────────────────────────────────────

model Tenant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents                  Agent[]
  channels                Channel[]
  contacts                Contact[]
  conversations           Conversation[]
  cases                   Case[]
  automationRules         AutomationRule[]
  automationExecutions    AutomationExecution[]
  automationActionResults AutomationActionResult[]
  interactionFlows        InteractionFlow[]
  flowExecutions          FlowExecution[]
  identityMaps            IdentityMap[]
  mergeSuggestions        MergeSuggestion[]
  notifications           Notification[]
  dailyStats              DailyStat[]
  tenantSettings          TenantSettings?
  campaigns               Campaign[]
  segments                Segment[]
  broadcasts              Broadcast[]
  webhookSubscriptions    WebhookSubscription[]
  portalActivities        PortalActivity[]
  portalSubmissions       PortalSubmission[]
  pointTransactions       PointTransaction[]
  shortLinks              ShortLink[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// 基礎：Agent（客服人員）
// ─────────────────────────────────────────────

model Agent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  email        String    @unique
  name         String
  avatarUrl    String?
  role         AgentRole @default(AGENT)
  isActive     Boolean   @default(true)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  teams         AgentTeamMember[]
  assignedConvs Conversation[]    @relation("AssignedAgent")
  assignedCases Case[]            @relation("AssignedAgent")
  caseEvents    CaseEvent[]
  sentMessages  Message[]
  notifications Notification[]

  @@map("agents")
  @@unique([tenantId, email])
}

enum AgentRole {
  ADMIN
  SUPERVISOR
  AGENT
}

model Team {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  licenseTeamId String? // 對應 License JSON teams[].teamId（平台方分配字串）
  createdAt     DateTime @default(now())

  members         AgentTeamMember[]
  cases           Case[]
  conversations   Conversation[]
  channelAccesses ChannelTeamAccess[]
  channelUsages   ChannelUsage[]

  @@map("teams")
}

model AgentTeamMember {
  agentId String @db.Uuid
  teamId  String @db.Uuid
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([agentId, teamId])
  @@map("agent_team_members")
}

// ─────────────────────────────────────────────
// 渠道（Channel）
// ─────────────────────────────────────────────

model Channel {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String      @db.Uuid
  channelType          ChannelType
  displayName          String
  isActive             Boolean     @default(true)
  credentialsEncrypted String // AES-256 加密後的 JSON
  settings             Json        @default("{}")
  webhookUrl           String? // 系統自動填入
  lastVerifiedAt       DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  channelIdentities ChannelIdentity[]
  conversations     Conversation[]
  teamAccesses      ChannelTeamAccess[]
  usages            ChannelUsage[]

  @@map("channels")
}

enum ChannelType {
  LINE
  FB
  WEBCHAT
  WHATSAPP
  TELEGRAM
  THREADS
}

// ─────────────────────────────────────────────
// Channel 多部門授權（ChannelTeamAccess）
// ─────────────────────────────────────────────

model ChannelTeamAccess {
  channelId   String   @db.Uuid
  teamId      String   @db.Uuid
  // full: 回覆+廣播 | reply_only: 僅回覆 | read_only: 僅讀入站
  accessLevel String   @default("full")
  grantedAt   DateTime @default(now())
  grantedById String?  @db.Uuid // Agent.id

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([channelId, teamId])
  @@index([teamId])
  @@map("channel_team_accesses")
}

// ─────────────────────────────────────────────
// 渠道計費記錄（ChannelUsage）
// ─────────────────────────────────────────────

model ChannelUsage {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId    String    @db.Uuid
  teamId       String?   @db.Uuid // 僅報表用，不影響 Credit 計算
  direction    Direction // INBOUND | OUTBOUND
  messageCount Int       @default(1)
  feeAmount    Float? // null = 免費渠道
  feeCurrency  String? // USD | TWD | null
  recordedAt   DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id])
  team    Team?   @relation(fields: [teamId], references: [id])

  @@index([channelId, recordedAt])
  @@index([teamId, recordedAt])
  @@map("channel_usages")
}

// 聯繫人（Contact）
// ─────────────────────────────────────────────

model Contact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  displayName String
  avatarUrl   String?
  phone       String?
  email       String?
  language    String   @default("zh-TW")
  isBlocked   Boolean  @default(false)
  isArchived  Boolean  @default(false)
  mergedIntoId String? @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  channelIdentities ChannelIdentity[]
  attributes        ContactAttribute[]
  tags              ContactTag[]
  relationsFrom     ContactRelation[]  @relation("FromContact")
  relationsTo       ContactRelation[]  @relation("ToContact")
  conversations     Conversation[]
  cases             Case[]
  longTermMemories  LongTermMemory[]
  identityMaps      IdentityMap[]
  portalSubmissions PortalSubmission[]
  pointTransactions PointTransaction[]

  @@index([phone])
  @@index([email])
  @@map("contacts")
}

model ChannelIdentity {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId   String      @db.Uuid
  channelId   String      @db.Uuid
  channelType ChannelType
  uid         String // LINE userId / FB psid / etc.
  profileName String?
  profilePic  String?
  linkedAt    DateTime    @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, uid])
  @@index([contactId])
  @@map("channel_identities")
}

model ContactAttribute {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId String @db.Uuid
  key       String // e.g. 'appliance_brand'
  value     String
  dataType  String @default("string") // string | number | date | boolean

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, key])
  @@map("contact_attributes")
}

model ContactRelation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromContactId String   @db.Uuid
  toContactId   String   @db.Uuid
  relationType  String // referrer / family / colleague
  notes         String?
  createdAt     DateTime @default(now())

  fromContact Contact @relation("FromContact", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact   Contact @relation("ToContact", fields: [toContactId], references: [id], onDelete: Cascade)

  @@unique([fromContactId, toContactId, relationType])
  @@map("contact_relations")
}

// ─────────────────────────────────────────────
// 標籤（Tag）
// ─────────────────────────────────────────────

model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @db.Uuid
  name        String
  color       String   @default("#6366f1")
  type        TagType  @default(MANUAL)
  scope       TagScope @default(CONTACT)
  description String?
  createdAt   DateTime @default(now())

  contactTags ContactTag[]

  @@unique([tenantId, name, scope])
  @@map("tags")
}

enum TagType {
  MANUAL
  AUTO
  SYSTEM
  CHANNEL
}

enum TagScope {
  CONTACT
  CONVERSATION
  CASE
}

model ContactTag {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId String    @db.Uuid
  tagId     String    @db.Uuid
  addedBy   String    @default("agent") // agent | system | automation
  addedById String?   @db.Uuid
  addedAt   DateTime  @default(now())
  expiresAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@map("contact_tags")
}

// ─────────────────────────────────────────────
// 對話與訊息（Conversation & Message）
// ─────────────────────────────────────────────

model Conversation {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String             @db.Uuid
  contactId     String             @db.Uuid
  channelId     String             @db.Uuid
  teamId        String?            @db.Uuid
  channelType   ChannelType
  status        ConversationStatus @default(ACTIVE)
  assignedToId  String?            @db.Uuid
  caseId        String?            @unique @db.Uuid
  unreadCount   Int                @default(0)
  lastMessageAt DateTime?
  botRepliesCount Int              @default(0)
  handoffReason String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  contact    Contact   @relation(fields: [contactId], references: [id])
  channel    Channel   @relation(fields: [channelId], references: [id])
  team       Team?     @relation(fields: [teamId], references: [id])
  assignedTo Agent?    @relation("AssignedAgent", fields: [assignedToId], references: [id])
  case       Case?     @relation(fields: [caseId], references: [id])
  messages   Message[]

  @@index([status])
  @@index([contactId])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  BOT_HANDLED
  AGENT_HANDLED
  CLOSED
}

model Message {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String     @db.Uuid
  direction      Direction  @default(INBOUND)
  senderType     SenderType
  senderId       String?    @db.Uuid
  contentType    String // text | image | file | flex | template | postback | ...
  content        Json
  metadata       Json       @default("{}")
  channelMsgId   String? // 渠道原始 message ID
  isRead         Boolean    @default(false)
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Agent?       @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CONTACT
  AGENT
  BOT
  SYSTEM
}

// ─────────────────────────────────────────────
// 案件（Case）
// ─────────────────────────────────────────────

model Case {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String     @db.Uuid
  contactId      String     @db.Uuid
  channelId      String     @db.Uuid
  conversationId String?    @db.Uuid
  title          String
  description    String?
  status         CaseStatus @default(OPEN)
  priority       Priority   @default(MEDIUM)
  category       String?
  assigneeId     String?    @db.Uuid
  teamId         String?    @db.Uuid
  slaPolicy      String? // SlaPolicy.id
  slaDueAt       DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  csatScore      Int? // 1~5
  csatComment    String?
  csatRespondedAt DateTime?
  csatSentAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  mergedIntoId String? @db.Uuid
  parentCaseId String? @db.Uuid

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  assignee     Agent?        @relation("AssignedAgent", fields: [assigneeId], references: [id])
  team         Team?         @relation(fields: [teamId], references: [id])
  conversation Conversation?

  mergedInto  Case?  @relation("MergedCases", fields: [mergedIntoId], references: [id])
  mergedCases Case[] @relation("MergedCases")
  parentCase  Case?  @relation("SubCases", fields: [parentCaseId], references: [id])
  subCases    Case[] @relation("SubCases")

  relationsFrom CaseRelation[] @relation("FromCase")
  relationsTo   CaseRelation[] @relation("ToCase")

  events CaseEvent[]
  notes  CaseNote[]

  @@index([status])
  @@index([assigneeId])
  @@index([slaDueAt])
  @@map("cases")
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model CaseEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId    String   @db.Uuid
  actorType String // agent | system | contact
  actorId   String?  @db.Uuid
  eventType String // created | assigned | status_changed | escalated | closed | ...
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  case  Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actor Agent? @relation(fields: [actorId], references: [id])

  @@index([caseId])
  @@map("case_events")
}

model CaseNote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId     String   @db.Uuid
  agentId    String   @db.Uuid
  content    String
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_notes")
}

model CaseRelation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromCaseId   String   @db.Uuid
  toCaseId     String   @db.Uuid
  relationType String // relates_to, blocks, duplicates
  createdAt    DateTime @default(now())

  fromCase Case @relation("FromCase", fields: [fromCaseId], references: [id], onDelete: Cascade)
  toCase   Case @relation("ToCase", fields: [toCaseId], references: [id], onDelete: Cascade)

  @@index([fromCaseId])
  @@index([toCaseId])
  @@map("case_relations")
}

model SlaPolicy {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String?  @db.Uuid
  name                 String
  priority             Priority
  firstResponseMinutes Int
  resolutionMinutes    Int
  warningBeforeMinutes Int      @default(30)
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([tenantId])
  @@map("sla_policies")
}

// ─────────────────────────────────────────────
// 自動化引擎（Automation Engine）
// ─────────────────────────────────────────────

model AutomationRule {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  name           String
  description    String?
  enabled        Boolean   @default(true)
  isActive       Boolean   @default(true)
  eventType      String    @default("")
  priority       Int       @default(0)
  stopProcessing Boolean   @default(false)
  stopOnMatch    Boolean   @default(false)
  scopeType      ScopeType @default(TENANT)
  scopeId        String?
  trigger        Json      @default("{}")
  conditionsJson Json      @default("{}")
  conditions     Json      @default("{}")
  actionsJson    Json      @default("[]")
  actions        Json      @default("[]")
  runCount       Int       @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  executions AutomationExecution[]
  logs       AutomationLog[]

  @@index([enabled])
  @@index([tenantId, isActive])
  @@index([eventType])
  @@map("automation_rules")
}

model AutomationExecution {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @db.Uuid
  eventType        String
  eventId          String?
  factSnapshot     Json
  candidateRuleIds String[]
  matchedRuleIds   String[]
  actionsExecuted  Json
  stoppedAt        String?
  status           ExecutionStatus
  createdAt        DateTime        @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  rule   AutomationRule? @relation(fields: [ruleId], references: [id])
  ruleId String?         @db.Uuid

  actionResults AutomationActionResult[]

  @@index([status])
  @@index([eventType])
  @@map("automation_executions")
}

model AutomationActionResult {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String             @db.Uuid
  executionId    String             @db.Uuid
  actionType     String
  params         Json
  beforeSnapshot Json?
  afterSnapshot  Json?
  status         ActionResultStatus
  errorMessage   String?
  rollbackable   Boolean            @default(false)
  rolledBackAt   DateTime?
  createdAt      DateTime           @default(now())

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  execution AutomationExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("automation_action_results")
}

enum ScopeType {
  TENANT
  TEAM
  CHANNEL
}

enum ExecutionStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum ActionResultStatus {
  SUCCESS
  FAILED
  ROLLED_BACK
}

model AutomationLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId     String   @db.Uuid
  tenantId   String?  @db.Uuid
  triggerRef String? // 觸發此規則的事件 ID
  success    Boolean
  actionsRan Json     @default("[]")
  errorMsg   String?
  createdAt  DateTime @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("automation_logs")
}

// ─────────────────────────────────────────────
// 知識庫（KM）
// ─────────────────────────────────────────────

model KmArticle {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String?                      @db.Uuid
  title          String
  content        String // Markdown
  summary        String
  category       String
  tags           String[]
  status         KmStatus                     @default(DRAFT)
  version        String?                      @default("1.0")
  teamId         String?                      @db.Uuid
  metadata       Json? // Any additional metadata
  embedding      Unsupported("vector(1536)")?
  embeddingModel String?
  viewCount      Int                          @default(0)
  helpfulCount   Int                          @default(0)
  createdById    String                       @db.Uuid
  updatedAt      DateTime                     @updatedAt
  createdAt      DateTime                     @default(now())

  @@index([tenantId, status])
  @@index([status])
  @@index([teamId])
  @@map("km_articles")
}

model LongTermMemory {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId      String                       @db.Uuid
  content        String // Summarized content
  embedding      Unsupported("vector(1536)")?
  embeddingModel String?
  metadata       Json? // { conversationId: string, topic: string, etc. }
  createdAt      DateTime                     @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("long_term_memories")
}

enum KmStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────
// 訊息模板（Message Template）
// ─────────────────────────────────────────────

model MessageTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?  @db.Uuid
  name            String
  description     String?
  category        String
  channelType     String   @default("universal") // line | fb | universal
  contentType     String // text | flex | quick_reply | fb_generic | fb_carousel
  body            Json // TemplateBody（含 flexJson / text / quickReplies 等）
  variables       Json     @default("[]") // TemplateVariable[]
  previewImageUrl String?
  isActive        Boolean  @default(true)
  isSystem        Boolean  @default(false)
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  views TemplateView[]

  @@index([tenantId])
  @@map("message_templates")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  agentId   String    @db.Uuid
  type      String
  title     String
  body      String
  clickUrl  String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@index([agentId, isRead])
  @@index([agentId, createdAt(sort: Desc)])
  @@map("notifications")
}

model DailyStat {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  date        DateTime @db.Date
  statType    String
  dimensionId String?
  data        Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date, statType, dimensionId])
  @@index([tenantId, statType, date])
  @@map("daily_stats")
}

model TenantSettings {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @unique @db.Uuid
  timezone    String   @default("Asia/Taipei")
  officeHours Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

// ─────────────────────────────────────────────
// 行銷（Marketing）
// ─────────────────────────────────────────────

model MarketingCampaign {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("marketing_campaigns")
}

model Campaign {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @db.Uuid
  name        String
  description String?
  status      String     @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  metrics     Json       @default("{}")
  createdById String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  broadcasts Broadcast[]

  @@index([tenantId, status])
  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

model Broadcast {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @db.Uuid
  campaignId     String?         @db.Uuid
  name           String
  channelId      String          @db.Uuid
  templateId     String          @db.Uuid
  segmentId      String?         @db.Uuid
  status         String          @default("draft")
  targetType     String          @default("all")
  targetConfig   Json            @default("{}")
  scheduledAt    DateTime?
  sentAt         DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalCount     Int             @default(0)
  successCount   Int             @default(0)
  failedCount    Int             @default(0)
  totalSent      Int             @default(0)
  totalDelivered Int             @default(0)
  totalReplied   Int             @default(0)
  createdById    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  segment    Segment?  @relation(fields: [segmentId], references: [id])
  recipients BroadcastRecipient[]

  @@index([tenantId, status])
  @@index([status])
  @@map("broadcasts")
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

model BroadcastRecipient {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  broadcastId    String    @db.Uuid
  contactId      String    @db.Uuid
  deliveryStatus String    @default("sent")
  replied        Boolean   @default(false)
  firstReplyAt   DateTime?
  caseId         String?   @db.Uuid
  caseCreatedAt  DateTime?
  sentAt         DateTime  @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, contactId])
  @@index([contactId, sentAt])
  @@map("broadcast_recipients")
}

// ─────────────────────────────────────────────
// LINE OA — Rich Menu
// ─────────────────────────────────────────────

model RichMenu {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId      String   @db.Uuid
  lineRichMenuId String // ID returned by LINE API
  name           String
  chatBarText    String
  configJson     Json // Full rich menu config JSON
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userBindings RichMenuUserBinding[]
  aliases      RichMenuAlias[]

  @@index([channelId])
  @@map("rich_menus")
}

model RichMenuUserBinding {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  richMenuId String   @db.Uuid
  channelId  String   @db.Uuid
  lineUserId String
  boundAt    DateTime @default(now())

  richMenu RichMenu @relation(fields: [richMenuId], references: [id], onDelete: Cascade)

  @@unique([channelId, lineUserId])
  @@index([richMenuId])
  @@map("rich_menu_user_bindings")
}

model RichMenuAlias {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  richMenuId  String   @db.Uuid
  channelId   String   @db.Uuid
  lineAliasId String // richMenuAliasId on LINE
  createdAt   DateTime @default(now())

  richMenu RichMenu @relation(fields: [richMenuId], references: [id], onDelete: Cascade)

  @@unique([channelId, lineAliasId])
  @@map("rich_menu_aliases")
}

// ─────────────────────────────────────────────
// LINE OA — Audience Group (Narrowcast)
// ─────────────────────────────────────────────

model AudienceGroup {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId           String   @db.Uuid
  segmentId           String?  @db.Uuid
  lineAudienceGroupId String // ID returned by LINE API
  description         String
  audienceType        String   @default("upload") // upload | click | impression
  size                Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([channelId])
  @@map("audience_groups")
}

// ─────────────────────────────────────────────
// LINE OA — Insight Snapshot (daily sync)
// ─────────────────────────────────────────────

model InsightSnapshot {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId        String   @db.Uuid
  snapshotDate     String // YYYYMMDD
  followers        Int      @default(0)
  blocks           Int      @default(0)
  targetedReaches  Int      @default(0)
  demographicsJson Json? // raw demographics response
  createdAt        DateTime @default(now())

  @@unique([channelId, snapshotDate])
  @@index([channelId, snapshotDate(sort: Desc)])
  @@map("insight_snapshots")
}

model Segment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?  @db.Uuid
  name       String
  description String?
  rules      Json? // legacy segment rules
  conditions Json     @default("[]") // SegmentCondition[]
  logic      String   @default("AND")
  contactCount Int     @default(0)
  createdById String?  @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  broadcasts Broadcast[]

  @@index([tenantId])
  @@map("segments")
}

// ─────────────────────────────────────────────
// 外部 Webhook 訂閱
// ─────────────────────────────────────────────

model WebhookSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @db.Uuid
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant?           @relation(fields: [tenantId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId, isActive])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String   @db.Uuid
  eventName      String
  payload        Json
  statusCode     Int?
  attempts       Int      @default(0)
  success        Boolean  @default(false)
  errorMessage   String?
  createdAt      DateTime @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

enum PortalActivityType {
  POLL
  FORM
  QUIZ
}

enum PortalActivityStatus {
  DRAFT
  PUBLISHED
  ENDED
  ARCHIVED
}

model PortalActivity {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String               @db.Uuid
  type        PortalActivityType
  status      PortalActivityStatus @default(DRAFT)
  title       String
  description String?
  coverImage  String?
  settings    Json                 @default("{}")
  startsAt    DateTime?
  endsAt      DateTime?
  publishedAt DateTime?
  createdById String               @db.Uuid
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  options     PortalOption[]
  fields      PortalField[]
  submissions PortalSubmission[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("portal_activities")
}

model PortalOption {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId String   @db.Uuid
  label      String
  imageUrl   String?
  sortOrder  Int      @default(0)
  isCorrect  Boolean  @default(false)

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("portal_options")
}

model PortalField {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId String   @db.Uuid
  fieldKey   String
  label      String
  fieldType  String   @default("text")
  options    Json     @default("[]")
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("portal_fields")
}

model PortalSubmission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId   String   @db.Uuid
  contactId    String   @db.Uuid
  tenantId     String   @db.Uuid
  answers      Json     @default("{}")
  score        Int?
  isWinner     Boolean  @default(false)
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())

  activity PortalActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  contact  Contact        @relation(fields: [contactId], references: [id])
  tenant   Tenant         @relation(fields: [tenantId], references: [id])

  @@index([activityId, contactId])
  @@map("portal_submissions")
}

model PointTransaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  contactId String   @db.Uuid
  amount    Int
  balance   Int
  type      String
  refId     String?  @db.Uuid
  note      String?
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId, contactId])
  @@index([contactId, createdAt(sort: Desc)])
  @@map("point_transactions")
}

model ShortLink {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  slug         String    @unique
  targetUrl    String
  title        String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  tagOnClick   String?   @db.Uuid
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  totalClicks  Int       @default(0)
  uniqueClicks Int       @default(0)
  createdById  String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  clickLogs ClickLog[]

  @@index([tenantId])
  @@index([slug])
  @@map("short_links")
}

model ClickLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortLinkId String   @db.Uuid
  contactId   String?  @db.Uuid
  ip          String?
  userAgent   String?
  referer     String?
  country     String?
  createdAt   DateTime @default(now())

  shortLink ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, createdAt(sort: Desc)])
  @@index([contactId])
  @@map("click_logs")
}

// ─────────────────────────────────────────────
// 互動畫布（Interaction Canvas）
// ─────────────────────────────────────────────

model InteractionFlow {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String     @db.Uuid
  name          String
  description   String?
  status        FlowStatus @default(DRAFT)
  triggerType   String // webhook | schedule | manual | event
  triggerConfig Json       @default("{}")
  maxStepLimit  Int        @default(100)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  nodes      InteractionNode[]
  executions FlowExecution[]

  @@index([tenantId, status])
  @@map("interaction_flows")
}

enum FlowStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model InteractionNode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId      String   @db.Uuid
  nodeType    NodeType
  label       String
  config      Json     @default("{}") // node-specific config (message body, delay ms, API url, …)
  position    Json     @default("{}") // { x: number, y: number } for canvas UI
  nextNodeId  String?  @db.Uuid // default next node
  falseNodeId String?  @db.Uuid // CONDITION false branch
  sortOrder   Int      @default(0)

  flow InteractionFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("interaction_nodes")
}

enum NodeType {
  TRIGGER
  MESSAGE
  WAIT
  CONDITION
  API_FETCH
  AI_GEN
  ACTION
}

// ─────────────────────────────────────────────
// 流程執行記錄（Flow Execution）
// ─────────────────────────────────────────────

model FlowExecution {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId        String         @db.Uuid
  contactId     String         @db.Uuid
  tenantId      String         @db.Uuid
  status        ExecutionState @default(RUNNING)
  currentNodeId String?        @db.Uuid
  contextVars   Json           @default("{}") // { ext: {…}, gen: {…}, contact: {…} }
  stepCount     Int            @default(0)
  resumeAt      DateTime? // set by WAIT nodes
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  flow   InteractionFlow @relation(fields: [flowId], references: [id])
  tenant Tenant          @relation(fields: [tenantId], references: [id])
  logs   FlowLog[]

  @@index([tenantId, status])
  @@index([resumeAt])
  @@index([contactId])
  @@map("flow_executions")
}

enum ExecutionState {
  RUNNING
  WAITING
  COMPLETED
  FAILED
}

model FlowLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId String   @db.Uuid
  nodeId      String?  @db.Uuid
  action      String // node_entered | message_sent | wait_scheduled | api_fetched | ai_generated | error
  result      Json     @default("{}")
  createdAt   DateTime @default(now())

  execution FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("flow_logs")
}

// ─────────────────────────────────────────────
// Template View（多通路模板版本）
// ─────────────────────────────────────────────

model TemplateView {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String             @db.Uuid
  channelType String // email | line | fb | whatsapp | universal
  contentType String // mjml_blocks | flex | quick_reply | hsm | text
  body        Json // block JSON for email, flex JSON for LINE, etc.
  variables   Json               @default("[]")
  status      TemplateViewStatus @default(DRAFT)
  reviewNotes String?
  submittedAt DateTime?
  approvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  template MessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, channelType])
  @@map("template_views")
}

enum TemplateViewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// 身分串接（Identity Stitching）
// ─────────────────────────────────────────────

model IdentityMap {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  contactId   String       @db.Uuid
  channelType ChannelType
  uid         String // LINE UID / FB PSID / etc.
  source      StitchSource
  confidence  Float        @default(1.0) // 0.0–1.0
  mergedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, channelType, uid])
  @@index([contactId])
  @@map("identity_maps")
}

enum StitchSource {
  LIFF_COOKIE
  PHONE_MATCH
  EMAIL_MATCH
  MANUAL
  OTP_VERIFIED
}

model MergeSuggestion {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @db.Uuid
  primaryContactId   String           @db.Uuid
  secondaryContactId String           @db.Uuid
  reason             String // same_phone | same_email | ai_similarity
  confidence         Float // 0.0–1.0
  status             SuggestionStatus @default(PENDING)
  reviewedById       String?          @db.Uuid
  reviewedAt         DateTime?
  createdAt          DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@map("merge_suggestions")
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}
