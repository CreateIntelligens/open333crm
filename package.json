{
  "name": "open333crm",
  "version": "0.2.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @open333crm/database exec prisma generate",
    "db:migrate": "pnpm --filter @open333crm/database exec prisma migrate dev",
    "db:seed": "pnpm --filter @open333crm/database exec prisma db seed",
    "db:studio": "pnpm --filter @open333crm/database exec prisma studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.33.0",
   "engines": {
    "node": ">=24.15.0"
  }
}
