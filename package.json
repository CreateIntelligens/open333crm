{
  "name": "open333crm",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @open333crm/db exec prisma generate",
    "db:migrate": "pnpm --filter @open333crm/db prisma migrate dev",
    "db:seed": "pnpm --filter @open333crm/db prisma db seed",
    "db:studio": "pnpm --filter @open333crm/db prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
