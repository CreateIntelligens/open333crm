NODE_ENV=production
API_PORT=3001

DATABASE_URL=postgresql://crm:crmpassword@postgres:5432/open333crm
REDIS_URL=redis://redis:6379
CACHE_DRIVER=redis

JWT_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d


CREDENTIAL_ENCRYPTION_KEY=change-me-32-bytes-encryption-key!!

API_BASE_URL=https://crm.example.com
NEXT_PUBLIC_WEB_URL=https://crm.example.com
# Optional: only set this when widget.js is served from a different public origin.
# WEB_BASE_URL=https://static.example.com

STORAGE_PROVIDER=minio
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=open333crm
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000
S3_SET_ACL=0

OLLAMA_BASE_URL=http://ollama:11434

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_TRANSPORT: console | file | both  (default: console)
#   console - stdout only (colorized, dev-friendly)
#   file    - daily rotating JSON log files only
#   both    - stdout + file simultaneously
LOG_TRANSPORT=console

# LOG_DIR: directory for log files when LOG_TRANSPORT=file|both (default: ./logs)
LOG_DIR=./logs

# LOG_MAX_FILES: retention period for rotated log files (default: 14d)
#   Accepts: "14d" (days), "30d", etc. Files older than this are auto-deleted and gzipped.
LOG_MAX_FILES=14d

# LOG_LEVEL: minimum log level (default: info)
#   Levels: error | warn | info | debug
LOG_LEVEL=info
