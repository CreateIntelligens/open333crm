# ─────────────────────────────────────────────────
# open333CRM — 環境變數設定範本
# 複製此檔案為 .env 並填入實際值
# ─────────────────────────────────────────────────

# Node
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://crm_user:crm_pass@localhost:5432/open333crm?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (最少 32 字元)
JWT_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars

# CORS (前端網址)
CORS_ORIGIN=http://localhost:3001

# ─── Storage Layer ───────────────────────────────
# 可選: minio | s3 | gcs
STORAGE_PROVIDER=minio

# MinIO (本地開發預設)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=open333crm
MINIO_PUBLIC_BASE_URL=http://localhost:9000/open333crm

# AWS S3 (生產用，改 STORAGE_PROVIDER=s3 時填)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-1
# S3_BUCKET=

# GCS (改 STORAGE_PROVIDER=gcs 時填)
# GCS_BUCKET=
# GCS_KEY_FILE=/path/to/keyfile.json

# ─── Channel Credentials Encryption ─────────────
# AES-256 金鑰，32 bytes
CREDENTIAL_ENCRYPTION_KEY=change-me-32-bytes-encryption-key!!

# ─── License (平台授權) ──────────────────────────
LICENSE_KEY=lic_your_tenant_key_here
LICENSE_FETCH_URL=https://license.open333crm.com/v1/licenses/lic_your_tenant_key_here
LICENSE_SIGNATURE_SECRET=your-hmac-signature-secret

# ─── Web Push (VAPID) ──────────────────────────
# 用 npx web-push generate-vapid-keys 產生
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ─── SMTP (Email 通知) ──────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notify@your-domain.com
SMTP_PASS=your-smtp-password

# ─── 前端 (apps/web 用) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
